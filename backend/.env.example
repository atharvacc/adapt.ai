# ── Claude (required for real AI generation) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI (GPT Image 1.5 for image generation) ──────────────────────────
OPENAI_API_KEY=sk-...

# ── xAI (Grok Imagine Video for video generation) ────────────────────────
XAI_API_KEY=xai-...

# ── Voyage AI (RAG vector embeddings, optional — falls back to keyword) ──
VOYAGE_API_KEY=pa-...

# ── LangSmith (agent tracing — optional) ──────────────────────────────────
# 1. Sign up at https://smith.langchain.com
# 2. Create an API key under Settings -> API Keys
# 3. Paste below. Traces appear at https://smith.langchain.com/
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=adapt-ai

# ── X / Twitter  (OAuth 2.0 with PKCE) ───────────────────────────────────
# 1. Go to https://developer.x.com/en/portal/dashboard
# 2. Create a Project + App (Free tier works)
# 3. Under "User authentication settings", enable OAuth 2.0
# 4. Set callback URL to: http://localhost:8000/v1/oauth/x/callback
# 5. Copy Client ID and Client Secret below
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── LinkedIn  (OAuth 2.0) ─────────────────────────────────────────────────
# 1. Go to https://www.linkedin.com/developers/apps
# 2. Create an app (needs a LinkedIn Page to associate with)
# 3. Under "Auth" tab, add redirect URL: http://localhost:8000/v1/oauth/linkedin/callback
# 4. Request "Sign In with LinkedIn using OpenID Connect" product
# 5. Copy Client ID and Client Secret below
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Instagram  (Meta OAuth 2.0) ──────────────────────────────────────────
# 1. Go to https://developers.facebook.com/apps/
# 2. Create an app (type: "Business")
# 3. Add "Facebook Login" product, set Valid OAuth Redirect URI to:
#    http://localhost:8000/v1/oauth/instagram/callback
# 4. Add "Instagram Basic Display" product
# 5. Copy App ID and App Secret below
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── TikTok  (OAuth 2.0) ──────────────────────────────────────────────────
# 1. Go to https://developers.tiktok.com/apps/
# 2. Create an app, request "Login Kit" + "Video List" scopes
# 3. Set redirect URI to: http://localhost:8000/v1/oauth/tiktok/callback
# 4. Copy Client Key and Client Secret below
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
